generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  avatar    String   @default("")
  note      String   @default("") // Max 60 chars
  birthdate String?  // Optional "YYYY-MM-DD"
  status    String   @default("online") // online, idle, offline
  socketId  String?  // Current Socket.IO connection ID
  points    Int      @default(0)
  streak    Int      @default(0)
  badges    String   @default("[]") // JSON string array of badge names
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messagesSent     Message[]
  dmSent           DirectMessage[] @relation("DmSender")
  dmReceived       DirectMessage[] @relation("DmReceiver")
  relationsInitiated UserRelation[] @relation("Relator")
  relationsReceived  UserRelation[] @relation("Related")
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  roomId    String   // "Friends Vibing" or "Romance Vibe"
  senderId  Int
  sender    User     @relation(fields: [senderId], references: [id])
  replyToId Int?     // If replying to another message
  replyTo   Message? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[] @relation("MessageReplies")
  isAnonymous Boolean @default(false)
  pollData  String?  // JSON string for polls {"question": "...", "options": {"A": 0, "B": 0}}
  createdAt DateTime @default(now())
}

model DirectMessage {
  id         Int      @id @default(autoincrement())
  content    String
  senderId   Int
  sender     User     @relation("DmSender", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("DmReceiver", fields: [receiverId], references: [id])
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model UserRelation {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("Relator", fields: [userId], references: [id])
  targetId  Int
  target    User     @relation("Related", fields: [targetId], references: [id])
  type      String   // "MUTE" or "BLOCK"
  createdAt DateTime @default(now())

  @@unique([userId, targetId, type])
}
